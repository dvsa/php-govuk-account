parameters:
    # Level 5 in PHPStan 2.x is roughly equivalent to the previous PHPStan 0.12
    # `level: max` with iterable-value/generic checks disabled. Increasing the
    # level meaningfully would require pervasive type hints on array-based
    # configuration surfaces (e.g. league/oauth2-client options) that are
    # outside the scope of this dependency-update.
    level: 5
    paths:
        - src
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            identifier: missingType.iterableValue
        -
            identifier: missingType.generics
        - '#Psr\\Cache\\InvalidArgumentException is not subtype of Throwable#'
