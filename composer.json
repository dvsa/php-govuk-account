{
  "name": "dvsa/php-govuk-account",
  "description": "A league/oauth2-client provider for GOV.UK One Login",
  "type": "library",
  "license": [
    "MIT"
  ],
  "authors": [
    {
      "name": "James Wragg",
      "email": "james.wragg@dvsa.gov.uk"
    }
  ],
  "keywords": [
    "govuk",
    "signin",
    "onelogin",
    "sdk",
    "dvsa"
  ],
  "autoload": {
    "psr-4": {
      "Dvsa\\GovUkAccount\\": "src/"
    }
  },
  "require": {
    "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
    "ext-json": "*",
    "firebase/php-jwt": "^6.10 || ^7.0",
    "guzzlehttp/guzzle": "^7.8",
    "guzzlehttp/psr7": "^2.6",
    "illuminate/collections": "^8.0 || ^9.0 || ^10.0 || ^11.0 || ^12.0",
    "league/oauth2-client": "^2.7",
    "psr/cache": "^1.0 || ^2.0 || ^3.0",
    "psr/http-client": "^1.0"
  },
  "require-dev": {
    "dvsa/coding-standards": "^1.0",
    "mockery/mockery": "^1.6",
    "phpstan/phpstan": "^1.12 || ^2.0",
    "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  }
}
